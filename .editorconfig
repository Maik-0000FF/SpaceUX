root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.{ts,tsx,js,jsx,json,css,html}]
indent_style = space
indent_size = 2

[*.{c,h}]
indent_style = tab
indent_size = 8

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
