root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.{ts,tsx,js,jsx,json,css,html}]
indent_style = space
indent_size = 2

[*.{c,h}]
indent_style = tab
indent_size = 8

# The native overlay is C++/QML in Qt style (4-space). This comes after
# the [*.{c,h}] rule so it overrides it for the overlay's own headers,
# while src/daemon headers keep the kernel tab/8 style above.
[src/overlay/**.{cpp,h,qml}]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
