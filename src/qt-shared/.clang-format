#
# Idiomatic Qt/LLVM C++ style for the overlay daemon: 4-space indent,
# attached braces, 80 columns. clang-format auto-selects the nearest
# config per directory, so src/daemon keeps its kernel-C style (8-wide
# tabs) from the repo-root .clang-format and this only applies here.
---
Language: Cpp
BasedOnStyle: LLVM

IndentWidth: 4
TabWidth: 4
UseTab: Never
ContinuationIndentWidth: 4
AccessModifierOffset: -4
NamespaceIndentation: None

ColumnLimit: 80
BreakBeforeBraces: Attach
PointerAlignment: Right
DerivePointerAlignment: false

AllowShortFunctionsOnASingleLine: All
AllowShortIfStatementsOnASingleLine: false
AllowShortLoopsOnASingleLine: false
AllowShortBlocksOnASingleLine: false
IndentCaseLabels: false

Cpp11BracedListStyle: true
Standard: c++17
SpaceBeforeParens: ControlStatements
SpacesBeforeTrailingComments: 1
MaxEmptyLinesToKeep: 1
KeepEmptyLinesAtTheStartOfBlocks: false

# Do not reflow comments. The reflow algorithm differs between clang-format
# versions (CI runs an older one than dev machines), which makes identical
# comments pass locally but fail in CI. Leaving comments untouched keeps the
# check deterministic across versions (the repo-root .clang-format does the
# same for the daemon). We keep comment lines within ColumnLimit by hand.
ReflowComments: false

# Keep Qt's container-loop macro treated like a control statement.
ForEachMacros: [Q_FOREACH, foreach]

# Sort within each blank-line-separated include block; preserve the
# blocks themselves (project header, Qt, LayerShellQt).
SortIncludes: true
IncludeBlocks: Preserve
