{
  "apiVersion": 1,
  "kind": "function",
  "id": "org.spaceux.example-launch",
  "name": "Example Launcher",
  "version": "0.1.0",
  "author": "Maik-0000FF",
  "license": "GPL-3.0-or-later",
  "actions": [
    {
      "name": "launch",
      "label": "Launch program",
      "description": "Spawn a desktop application as a fire-and-forget subprocess.",
      "config": {
        "command": {
          "kind": "string",
          "label": "Command",
          "placeholder": "firefox --new-window https://example.com",
          "default": ""
        }
      }
    }
  ],
  "menu": {
    "root": {
      "label": "",
      "branches": [
        {
          "label": "Files",
          "action": {
            "id": "org.spaceux.example-launch/launch",
            "config": { "command": "xdg-open ." }
          }
        },
        {
          "label": "Browser",
          "action": {
            "id": "org.spaceux.example-launch/launch",
            "config": { "command": "xdg-open https://example.com" }
          }
        }
      ]
    }
  }
}
