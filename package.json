{
  "name": "spaceux",
  "version": "0.0.1",
  "private": true,
  "license": "GPL-3.0-or-later",
  "description": "Radial menu UI for 3Dconnexion SpaceMouse devices.",
  "main": "dist-electron/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && tsc -p tsconfig.electron.json && npm run build:preload",
    "build:preload": "esbuild src/main/preload.ts src/main/editor-preload.ts --bundle --platform=node --format=cjs --external:electron --outdir=dist-electron/main --out-extension:.js=.cjs",
    "build:daemon": "cmake -S . -B build/daemon && cmake --build build/daemon",
    "build:all": "npm run build:daemon && npm run build",
    "start": "electron dist-electron/main/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^42.1.0",
    "esbuild": "^0.28.0",
    "prettier": "3.8.3",
    "sass": "^1.83.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "dbus-next": "^0.10.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
